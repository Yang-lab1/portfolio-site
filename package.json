{
  "name": "yang-lin-portfolio-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "preview:static": "node tools/serve-dist.mjs",
    "prepare:helix": "node tools/prepare-helix-frames.mjs",
    "render:helix": "node tools/render-helix-video.mjs",
    "audit:china": "node tools/china-readiness-audit.mjs",
    "predeploy:china": "npm run build && node tools/china-readiness-audit.mjs --strict",
    "package:china": "npm run predeploy:china && node tools/package-china-dist.mjs && node tools/verify-release-package.mjs --latest",
    "verify:url": "node tools/verify-live-url.mjs",
    "verify:detail-format": "node tools/verify-detail-format.mjs",
    "verify:domain": "node tools/verify-domain-readiness.mjs",
    "verify:release": "node tools/verify-release-package.mjs",
    "verify:supabase": "node tools/verify-supabase-config.mjs",
    "generate:evidence": "node tools/generate-deployment-evidence.mjs",
    "verify:launch-goal": "node tools/verify-launch-goal.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "@vitejs/plugin-react": "^6.0.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.14.0",
    "motion": "^12.40.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "playwright": "^1.61.0"
  }
}
